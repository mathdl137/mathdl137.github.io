        RowBox[{
         RowBox[{"d", "^", "2"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"d", "^", "2"}], "-", "1"}], ")"}]}]}]]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Lam", "*", "M2"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
