 RowBox[{
  RowBox[{"polyMax", "[", 
   RowBox[{"p_", ",", "a_", ",", "b_", ",", "dx_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "d", ",", "pValues", ",", "M2", ",", "Lam", ",", "Nsub", ",", 
      "coeffList"}], "}"}], ",", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"PolynomialQ", "[", 
         RowBox[{"p", ",", "x"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{
        "Return", "[", "\"\<Error: p must be a polynomial in x.\>\"", "]"}], 
        ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"coeffList", "=", 
      RowBox[{"CoefficientList", "[", 
       RowBox[{"p", ",", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"Exponent", "[", 
       RowBox[{"p", ",", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Nsub", "=", 
      RowBox[{"Ceiling", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"b", "-", "a"}], ")"}], "/", "dx"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"6", " ", 
          RowBox[{"Nsub", "^", "2"}]}], "-", 
         RowBox[{
          RowBox[{"d", "^", "2"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"d", "^", "2"}], "-", "1"}], ")"}]}]}], "<=", "0"}], ",", 
       RowBox[{
        RowBox[{
        "Return", "[", "\"\<Error: lambda must be positive.\>\"", "]"}], 
        ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"pValues", "=", 
      RowBox[{"ParallelTable", "[", 
       RowBox[{
        RowBox[{"FromDigits", "[", 
         RowBox[{
          RowBox[{"Reverse", "[", "coeffList", "]"}], ",", 
          RowBox[{"a", "+", 
           RowBox[{"k", "*", "dx"}]}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", "Nsub"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"M2", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"Abs", "[", "pValues", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Lam", "=", 
