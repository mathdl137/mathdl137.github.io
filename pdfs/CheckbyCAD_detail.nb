         RowBox[{"p", ",", "x"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{
        "Return", "[", "\"\<Error: p must be a polynomial in x.\>\"", "]"}], 
        ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"coeffList", "=", 
      RowBox[{"CoefficientList", "[", 
       RowBox[{"p", ",", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"Exponent", "[", 
       RowBox[{"p", ",", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Nsub", "=", 
      RowBox[{"Ceiling", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"b", "-", "a"}], ")"}], "/", "dx"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
